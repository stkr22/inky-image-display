{
	"name": "inky-image-display-dev-environment",
	"dockerComposeFile": "compose.yml",
	"service": "dev",
	"remoteUser": "vscode",
	"workspaceFolder": "/workspaces/inky-image-display",
    "features": {
        "ghcr.io/stkr22/devcontainer-features/uv:1.1.0": {},
		"ghcr.io/devcontainer-community/devcontainer-features/starship.rs:1": {},
		"ghcr.io/devcontainers/features/node:2.0.0": {
		"version": "lts"
		}
    },
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"samuelcolvin.jinjahtml",
				"streetsidesoftware.code-spell-checker",
				"christian-kohler.path-intellisense",
				"charliermarsh.ruff",
				"astral-sh.ty",
				"tamasfe.even-better-toml",
				"github.vscode-github-actions",
				"oderwat.indent-rainbow",
				"mhutchie.git-graph",
				"vivaxy.vscode-conventional-commits"
			],
			"settings": {
				"files.trimFinalNewlines": true,
				"files.trimTrailingWhitespace": true,
				"files.insertFinalNewline": true,
				"[python]": {
					"editor.formatOnSave": true,
					"editor.codeActionsOnSave": {
						"source.fixAll": "explicit",
						"source.organizeImports": "explicit"
					},
					"editor.defaultFormatter": "charliermarsh.ruff"
				},
				"python.defaultInterpreterPath": "/workspaces/.venv/bin/python",
				"python.testing.unittestEnabled": false,
				"python.testing.pytestEnabled": true,
				"python.languageServer": "None",
				"cSpell.files": [
					"src"
				]
			}
		}
	},
	"postCreateCommand": {
		"uv-sync": "uv sync --all-packages --group dev",
		"uv-pre-commit": "uv tool run pre-commit install",
		"playwright-install": "npx -y playwright install-deps chromium && npx -y playwright install chromium"
	}
}
