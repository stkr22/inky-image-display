# Build stage: React frontend (served by the API when API_WEB_DIST_PATH points at it).
# --platform=$BUILDPLATFORM: the dist output is platform-independent, so always
# build natively instead of once per target arch under QEMU.
FROM --platform=$BUILDPLATFORM docker.io/library/node:24-trixie-slim AS build-web

WORKDIR /web
COPY packages/web/package.json packages/web/package-lock.json ./
RUN npm ci --no-audit --no-fund
COPY packages/web/ ./
RUN npm run build

# Build stage: Python 3.14.4-trixie
FROM docker.io/library/python:3.14.4-trixie@sha256:8f84f00e6981bff45ce0ed100019142e13a397412bc130425f34ece42906cd48 AS build-python

ENV UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    UV_PYTHON_DOWNLOADS=never \
    PYTHONUNBUFFERED=1

# Install uv.
COPY --from=ghcr.io/astral-sh/uv:0.11.7@sha256:240fb85ab0f263ef12f492d8476aa3a2e4e1e333f7d67fbdd923d00a506a516a /uv /uvx /bin/

# Set working directory
WORKDIR /app

# Copy workspace files needed for dependency resolution
COPY pyproject.toml uv.lock ./
COPY packages/shared/ packages/shared/
COPY packages/api/ packages/api/

RUN --mount=type=cache,target=/root/.cache \
    uv sync --package inky-image-display-api --no-dev --no-editable

# Runtime stage: Python 3.14.4-slim-trixie
FROM docker.io/library/python:3.14.4-slim-trixie@sha256:538a18f1db92b4210a0b71aca2d14c156a96dedbe8867465c8ff4dce04d2ec39

ENV PYTHONUNBUFFERED=1

# Create non-root user
RUN addgroup --system --gid 1001 appuser && adduser --system --uid 1001 --no-create-home --ingroup appuser appuser

WORKDIR /app
COPY --from=build-python /app/.venv /app/.venv
COPY --from=build-web /web/dist /app/web

ENV PATH="/app/.venv/bin:$PATH" \
    API_WEB_DIST_PATH=/app/web
USER appuser

ENTRYPOINT ["inky-image-display-api"]
